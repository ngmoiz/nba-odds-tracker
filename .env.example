# ─────────────────────────────────────────────────────────────
# Variables d'environnement — NBA Odds Tracker
#
# Copier ce fichier en `.env` (jamais commité) et renseigner les valeurs.
# Contient uniquement des secrets et des paramètres propres à la machine ;
# les seuils et le planning sont dans config.yaml.
# ─────────────────────────────────────────────────────────────

# Clé API The Odds API (https://the-odds-api.com) — pour la collecte des cotes.
ODDS_API_KEY=

# Clé API balldontlie (https://www.balldontlie.io) — pour les scores finaux
# (évaluateur). Plan gratuit : NBA/WNBA inclus. Réservée aux résultats, jamais aux
# cotes (The Odds API reste la seule source de cotes).
BALLDONTLIE_API_KEY=

# Token du bot Telegram, fourni par @BotFather.
TELEGRAM_BOT_TOKEN=

# Identifiant de la conversation Telegram où envoyer les messages.
TELEGRAM_CHAT_ID=

# Chemin du fichier de base SQLite (défaut : ./data/nba_odds.db).
DATABASE_PATH=./data/nba_odds.db

# Niveau de log : DEBUG / INFO / WARNING / ERROR.
LOG_LEVEL=INFO
