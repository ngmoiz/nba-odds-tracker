# Secrets — ne JAMAIS commiter (règle 0.4.1)
.env

# Base de données SQLite (données locales, jamais versionnées)
data/
*.db
*.sqlite
*.sqlite3

# Environnement virtuel Python / uv
.venv/
# uv.lock EST versionné (application → installs reproductibles en CI/Docker/EC2).

# Caches Python
__pycache__/
*.py[cod]
*$py.class

# Caches outils
.pytest_cache/
.ruff_cache/
.mypy_cache/

# Réglages locaux Claude Code (permissions propres à la machine)
.claude/settings.local.json

# Divers IDE / OS
.vscode/
.idea/
.DS_Store
